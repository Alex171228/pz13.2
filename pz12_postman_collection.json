{
  "info": {
    "name": "PZ12 — REST vs GraphQL",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Практическое занятие №12: сравнение REST и GraphQL"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8082" },
    { "key": "auth_url", "value": "http://localhost:8081" },
    { "key": "token", "value": "" },
    { "key": "task_id", "value": "" },
    { "key": "new_task_id", "value": "" }
  ],
  "item": [
    {
      "name": "0. Auth",
      "item": [
        {
          "name": "Login → получить token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.test('Token saved', function() { pm.expect(json.token).to.be.a('string'); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{auth_url}}/v1/auth/login",
              "host": ["{{auth_url}}"],
              "path": ["v1", "auth", "login"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student\",\n  \"password\": \"student\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "1. REST — список задач",
      "item": [
        {
          "name": "GET /v1/tasks — все поля (over-fetching)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('Массив задач', function() { pm.expect(json).to.be.an('array'); });",
                  "if (json.length > 0) {",
                  "  pm.test('Содержит 6 полей (over-fetching)', function() {",
                  "    var keys = Object.keys(json[0]);",
                  "    pm.expect(keys).to.include.members(['id','title','description','due_date','done','created_at']);",
                  "  });",
                  "  pm.collectionVariables.set('task_id', json[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["v1", "tasks"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "2. REST — детали задачи",
      "item": [
        {
          "name": "GET /v1/tasks/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('Содержит id и title', function() {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('title');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "tasks", "{{task_id}}"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "3. REST — создание задачи",
      "item": [
        {
          "name": "POST /v1/tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.test('Задача создана', function() {",
                  "  pm.expect(json.title).to.eql('Сравнить REST и GraphQL');",
                  "  pm.expect(json.done).to.eql(false);",
                  "});",
                  "pm.collectionVariables.set('new_task_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["v1", "tasks"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Сравнить REST и GraphQL\",\n  \"description\": \"Практическая работа №12\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. REST — обновление задачи",
      "item": [
        {
          "name": "PATCH /v1/tasks/:id — done=true",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('done = true', function() { pm.expect(json.done).to.eql(true); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/v1/tasks/{{new_task_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "tasks", "{{new_task_id}}"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"done\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "5. REST — ошибка 404",
      "item": [
        {
          "name": "GET /v1/tasks/unknown → 404",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function() { pm.response.to.have.status(404); });",
                  "pm.test('Сообщение об ошибке', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.error).to.include('not found');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/tasks/unknown",
              "host": ["{{base_url}}"],
              "path": ["v1", "tasks", "unknown"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
